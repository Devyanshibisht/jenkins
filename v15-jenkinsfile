pipeline {
    agent any
	tools {
	    maven "3.8.6"
	 	}
	stages {
	    stage('Git CheckOut') {
		    steps {
			   checkout([$class: 'GitSCM', branches: [[name:'*/main']], userRemoteConfigs: [[url: 'https://github.com/Devyanshibisht/Profile-card']]])
			}
		}
        stage('Clean and Install') {
            steps {
                bat 'mvn clean install'
            }
        }
        stage ('Code Quality'){
            steps {
                    withSonarQubeEnv('SonarQube server') {
                bat 'mvn sonar:sonar'
                }
             }
        }
		
    }
}
